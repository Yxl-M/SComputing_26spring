--- a/src/sampling_demo.c
+++ b/src/sampling_demo.c
@@ -1,3 +1,19 @@
+/*
+ * Homework 04 modification / 作业 04 修改说明
+ *
+ * English:
+ * This patch implements Part 7, Option B: Change the observation time.
+ * We keep the sampling frequency fixed at 512 Hz, but increase the number
+ * of samples in the short_record case from 64 to 512.  Therefore the total
+ * observation time increases from 0.125 s to 1.0 s, and the FFT bin spacing
+ * improves from 8 Hz to 1 Hz.
+ *
+ * 中文：
+ * 这个 patch 对应第 7 部分的 Option B：改变观测时间。
+ * 我们保持采样频率 512 Hz 不变，只把 short_record 情况下的样本数
+ * 从 64 增加到 512。因此总观测时间从 0.125 s 增加到 1.0 s，
+ * FFT 的频率分辨率从 8 Hz 提高到 1 Hz。
+ */
@@
         {
             "short_record",
-            "The signal contains 50 Hz and 55 Hz, but the record is too short, so the FFT cannot separate nearby frequencies cleanly.",
+            "The signal contains 50 Hz and 55 Hz. This modified case uses a longer record, so the FFT can separate the nearby frequencies more clearly.",
             close_frequencies_signal,
             512.0,
-            64U,
+            512U,
